{
  "version": "1.1",
  "selection_rule": "Choose by communication job, not product category or visual style. Use one primary template and at most one secondary template.",
  "templates": [
    {
      "template_id": "T01_HERO_CAMPAIGN",
      "name": "主活动主视觉",
      "use_for": ["campaign cover", "countdown", "launch", "one dominant event message"],
      "avoid_for": ["dense product catalog", "rules longer than four short steps"],
      "recommended_ratios": ["3:4", "4:5", "9:16", "2.3:1"],
      "capacity": {"primary_messages": 1, "benefit_anchors": 1, "support_blocks_max": 2},
      "regions": [
        "brand or campaign marker",
        "dominant title field",
        "hero person or product field",
        "protected date/time and benefit field",
        "optional CTA or qualifier footer"
      ],
      "protected": ["complete title", "date/time", "primary benefit", "required qualifier"],
      "adaptation": "If content exceeds capacity, move details into a second T07 benefit/rules card rather than shrinking the hero."
    },
    {
      "template_id": "T02_WEEKLY_SCHEDULE",
      "name": "周排期/系列预告",
      "use_for": ["multi-day schedule", "series preview", "today's sessions"],
      "avoid_for": ["one hero product", "long product descriptions"],
      "recommended_ratios": ["3:4", "4:5", "wechat-longform"],
      "capacity": {"date_columns_mobile_max": 4, "lines_per_schedule_card_max": 3},
      "regions": [
        "schedule title",
        "equal-width date cards",
        "today or priority session highlight",
        "optional hero visual",
        "platform or timing footer"
      ],
      "protected": ["dates", "times", "session names", "today marker"],
      "adaptation": "For more than four dates, paginate or use a vertical timeline; do not compress seven columns into one mobile screen."
    },
    {
      "template_id": "T03_LIVE_TIME_CAPSULE",
      "name": "开播时间胶囊",
      "use_for": ["reusable date/time strip", "article separator", "conversion reminder"],
      "avoid_for": ["standalone campaign poster", "multi-rule interaction"],
      "recommended_ratios": ["4.5:1", "6:1"],
      "capacity": {"date": 1, "time": 1, "cta_characters_max": 12},
      "regions": ["date field", "live-state marker", "time field", "short CTA"],
      "protected": ["date", "time", "CTA"],
      "adaptation": "Keep transparent exterior padding and render all text deterministically."
    },
    {
      "template_id": "T04_SINGLE_PRODUCT_STORY",
      "name": "单品/穿搭故事卡",
      "use_for": ["one product", "one outfit", "hero item with details", "product storytelling"],
      "avoid_for": ["more than three equal-priority products"],
      "recommended_ratios": ["3:4", "4:5", "2:3"],
      "capacity": {"hero_subjects": 1, "detail_images_max": 2, "selling_points_max": 3},
      "regions": [
        "brand and product name",
        "55-70 percent hero subject field",
        "zero-to-two detail image fields",
        "selling-point field",
        "optional price or benefit anchor"
      ],
      "protected": ["product identity", "required package features", "selling points", "price qualifier"],
      "adaptation": "If the card must repeat in a list, use T05 geometry and retain T04 subject emphasis."
    },
    {
      "template_id": "T05_MULTI_PRODUCT_CATALOG",
      "name": "多商品清单",
      "use_for": ["product catalog", "multi-brand list", "one-to-four products per screen", "repeatable commerce cards"],
      "avoid_for": ["one emotional campaign message", "unstructured long-form story"],
      "recommended_ratios": ["3:4", "4:5", "wechat-longform"],
      "capacity": {"products_per_screen_max": 4, "selling_points_per_product_max": 2},
      "regions": [
        "category or section title",
        "repeatable product modules",
        "consistent image field",
        "product identity and short selling points",
        "optional benefit badge"
      ],
      "protected": ["product identity", "recognizable product image", "price mechanism", "qualifier"],
      "adaptation": "Use one-column emphasis for a priority item and a two-by-two grid for equal items. Paginate before product recognition fails."
    },
    {
      "template_id": "T06_THEMATIC_LONGFORM",
      "name": "主题长图内容",
      "use_for": ["regional story", "food or craft theme", "educational long-form", "chaptered product narrative"],
      "avoid_for": ["single-screen urgent announcement"],
      "recommended_ratios": ["wechat-longform", "carousel"],
      "capacity": {"body_characters_per_chapter_guidance": [60, 100], "rhythm_change_every_chapters": [2, 3]},
      "regions": [
        "theme opener and hook",
        "repeatable chapter modules",
        "chapter title and real metadata",
        "subject image",
        "closing date/time and CTA"
      ],
      "protected": ["chapter order", "names and locations", "date/time", "CTA", "required source facts"],
      "adaptation": "Keep chapter scaffolding consistent while changing image crop or whitespace rhythm every two to three chapters."
    },
    {
      "template_id": "T07_INTERACTION_BENEFIT",
      "name": "福利互动/猜题图",
      "use_for": ["benefit explainer", "red-envelope interaction", "guessing game", "participation rules", "answer-later graphic"],
      "avoid_for": ["dense product catalog without interaction"],
      "recommended_ratios": ["3:4", "4:5", "9:16"],
      "capacity": {"rule_steps_max": 4, "primary_questions": 1, "primary_benefits": 1},
      "regions": [
        "interaction or benefit title",
        "dominant question, puzzle, or benefit field",
        "numbered rule field",
        "participation and announcement details",
        "compliance footer"
      ],
      "protected": ["question or benefit", "all rule conditions", "participation method", "announcement time", "disclaimer"],
      "adaptation": "Separate the answer from the question when required. Move long legal copy to a protected footer rather than shrinking rules."
    }
  ]
}
